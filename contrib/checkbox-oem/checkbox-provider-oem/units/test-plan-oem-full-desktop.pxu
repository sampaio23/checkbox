#
# Test plans and (optionally) jobs unique to the IoT devices running Ubuntu Desktop.
#

id: oem-iot-desktop-24-04
unit: test plan
_name: OEM-IOT - Full manual + automated OEM tests for Ubuntu Desktop 24.04
_description:
  Combined manual and automated test plans for IoT devices running Ubuntu Desktop.
include:
nested_part:
  oem-iot-desktop-24-04-automated
  oem-iot-desktop-24-04-manual
  oem-iot-desktop-24-04-stress
certification_status_overrides:
  apply blocker to .*

id: oem-iot-desktop-24-04-automated
unit: test plan
_name: OEM-IOT - Automated only OEM tests for Ubuntu Desktop 24.04
_description:
  Ubuntu Desktop OEM test plan for the IoT devices. This test plan contains
  all of the automated tests used to validate the IoT devices.
include:
nested_part:
  oem-automated
exclude:
certification_status_overrides:
  apply blocker to .*

id: oem-iot-desktop-24-04-manual
unit: test plan
_name: OEM-IOT - Manual only OEM tests for Ubuntu Desktop 24.04
_description:
  Ubuntu Desktop OEM test plan for the IoT devices. This test plan contains
  all of the tests that require manual control of device hardware
  or some other user input to complete.
estimated_duration: 3600
include:
nested_part:
  oem-manual
exclude:
certification_status_overrides:
  apply blocker to .*

id: oem-iot-desktop-24-04-stress
unit: test plan
_name: OEM-IOT - Stress only OEM tests for Ubuntu Desktop 24.04
_description:
    Ubuntu Desktop OEM test plan that includes all stress tests required for IoT devices
include:
nested_part:
  oem-stress
exclude:
certification_status_overrides:
  apply blocker to .*
