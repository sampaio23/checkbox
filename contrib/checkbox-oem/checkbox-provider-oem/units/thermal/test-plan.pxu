id: oem-thermal-full
unit: test plan
_name: Thermal thermal tests
_description: Full thermal thermal tests for devices
include:
nested_part:
  oem-thermal-automated
  oem-thermal-manual

id: oem-thermal-automated
unit: test plan
_name: Thermal auto tests
_description: Automated thermal tests for devices
bootstrap_include:
  com.canonical.certification::device
include:
  thermal/check-thermald-unknown-cond
  thermal/intel-cpu-thermal
  thermal/intel-p-state
  thermal/intel-powerclamp
  thermal/intel-rapl
  thermal/intel-rapl-mmio_.*
  thermal/intel-x86-pkg-temp-thermal
  thermal/proc_thermal_.*
  thermal/thermal-policy-set_.*
  thermal/thermald
  thermal/valid-thermal-zone-trip-points

id: oem-thermal-manual
unit: test plan
_name: Thermal manual tests
_description: Manual thermal tests for devices
include:
