name: checkbox-ce-oem
summary: Checkbox CE OEM test runner and public providers$APPEND_SUMMARY
description: "Checkbox CE OEM test runner and public providers$APPEND_SUMMARY"
confinement: strict
grade: stable

version: '$SNAP_VERSION-$SERIESNAME'

base: $SNAPBASE

slots:
  custom-frontend:
    interface: content
    content: custom-frontend
    read:
      - /

package-repositories:
  - type: apt
    ppa: checkbox-dev/stable # used to pull the installation machinery

parts:
  checkbox-provider-ce-oem:
    plugin: dump
    source: checkbox-provider-ce-oem
    source-type: local
    build-environment:
      - PYTHONPYCACHEPREFIX: "/tmp"
    stage-packages:
$PROVIDER_EXTRA_PACKAGES
      - mtd-utils
      - u-boot-tools
      - v4l-utils
      - device-tree-compiler
      - linuxptp
      - snmp
      - gpsd
    override-prime: |
$OVERRIDE_PRIME_COMMAND
    override-build: |
      export PYTHONPATH=/snap/$CHECKBOX_RUNTIME/current/lib/$PYTHONVER/site-packages/
      for path in $(find "/snap/$CHECKBOX_RUNTIME/current/providers/" -mindepth 1 -maxdepth 1 -type d); do export PROVIDERPATH=$path${PROVIDERPATH:+:$PROVIDERPATH}; done
      python3 manage.py validate
      python3 manage.py build
      python3 manage.py install --layout=relocatable --prefix=/providers/checkbox-provider-ce-oem --root="$${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PART_INSTALL"
    build-packages:
      - checkbox-ng
      - python3-dev
      - python3-jinja2
      - python3-packaging
      - python3-urwid
      - python3-xlsxwriter
      - python3-requests-oauthlib
  input-pcspkr:
    plugin: nil
    after: [checkbox-provider-ce-oem]
    build-packages:
      - gcc
      - libc6-dev
    override-build: |
      mkdir -p ${${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PART_INSTALL}/usr/bin
      gcc ${${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PROJECT_DIR}/checkbox-provider-ce-oem/src/input-pcspkr.c -o ${${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PART_INSTALL}/usr/bin/beep
  xtest:
    plugin: dump
    after: [checkbox-provider-ce-oem]
    source: https://github.com/OP-TEE/optee_test.git
    source-type: git
    build-snaps:
      - $CHECKBOX_RUNTIME
    build-packages:
      - jq
      - python3-requests-unixsocket
    build-environment:
      - PART_DEST: ${${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PART_INSTALL}/providers/checkbox-provider-ce-oem/data/
      - PROVIDER_SRC: ${${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PROJECT_DIR}/checkbox-provider-ce-oem
      - PYTHONPATH: /snap/$CHECKBOX_RUNTIME/current/lib/$PYTHONVER/site-packages/
    override-pull: |
      snapcraftctl pull
      cp ${PROVIDER_SRC}/data/xtest_supported_version.json .
      cp ${PROVIDER_SRC}/bin/optee_helper.py .
      cp ${PROVIDER_SRC}/bin/look_up_xtest.py .
      cp ${PROVIDER_SRC}/bin/xtest_install_ta.py .
    override-build: |
      for ver in `cat xtest_supported_version.json | jq -r .xtest_suite_tag[]`; do
          git checkout $ver
          python3 optee_helper.py parse_xtest_src $ver
      done
      mkdir -p ${PART_DEST}
      cp -v optee-test-*.json ${PART_DEST}
  spidev-test:
    plugin: make
    source: https://github.com/torvalds/linux.git
    source-type: git
    source-depth: 1
    source-subdir: tools/spi
  parts-meta-info:
    plugin: nil
    override-build: |
      $OVERRIDE_BUILD_COMMAND
      for p in `ls -d ../../*`; do
          if [ -d $p/src ]; then
            (cd $p/src
                if [ -d $p/src/.git ]; then
                    (echo `basename $p`\: && git show --pretty=format:"%h%d %aN %ci%n%s%n" -q ; echo ) >> $${SNAPCRAFT_FOLDER_PREFIX}CRAFT_PART_INSTALL/parts_meta_info
                fi # for additional `source-type` support, elif them here
            )
          fi
      done
    after: [checkbox-provider-ce-oem]
  launchers:
    plugin: dump
    source: launchers/
    build-attributes: [no-patchelf]
    organize:
      '*': bin/
  config-variables:
    plugin: dump
    source: config/
    build-attributes: [no-patchelf]

$EXTRA_CONFIG
